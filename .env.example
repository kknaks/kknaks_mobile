SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# Comma-separated Slack user IDs allowed to trigger the bot.
# Empty = deny all (safe default). Find your ID in Slack profile > More > Copy member ID.
ALLOWED_SLACK_USERS=

REDIS_URL=redis://127.0.0.1:36379
REDIS_NAMESPACE=kknaks_mobile

WORK_DIR=/path/to/projects

UPLOAD_DIR=${WORK_DIR}/.kknaks_mobile_uploads
